# Keeping Cadence API — environment variables (set these in Vercel).

# Neon Postgres connection string. Use the POOLED connection string from the
# Neon dashboard (host contains "-pooler"); it suits serverless.
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Secret for signing session tokens. Any long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Browser origin(s) allowed to call the API, comma-separated. Use your live
# site origin. ("*" allows any origin — fine for local testing only.)
ALLOWED_ORIGINS=https://mattdanusergrant.github.io

# --- Stripe (optional; billing endpoints return 503 until these are set) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
CHECKOUT_SUCCESS_URL=https://mattdanusergrant.github.io/keeping-cadence/?billing=success
CHECKOUT_CANCEL_URL=https://mattdanusergrant.github.io/keeping-cadence/?billing=cancel
